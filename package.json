{
  "name": "solana-reliability-sdk",
  "version": "0.1.0",
  "description": "Systems-grade SDK that improves RPC and transaction reliability for Solana dApps.",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "solana-reliability-sdk": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "cli": "tsx src/cli/main.ts",
    "example:basic": "tsx examples/basic.ts",
    "example:relay-fallback": "tsx examples/relay-fallback.ts",
    "example:wallet-adapter": "tsx examples/wallet-adapter.ts",
    "example:demo": "tsx examples/judge-demo.ts",
    "example:devnet": "tsx examples/devnet-smoke.ts",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@solana-program/system": "^0.12.2",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.9.0",
    "@solana/kit-plugin-rpc": "^0.11.1",
    "@solana/kit-plugin-signer": "^0.10.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
